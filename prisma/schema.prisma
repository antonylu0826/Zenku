// DO NOT MODIFY THIS FILE                                                                  //
// This file is automatically generated by ZenStack CLI and should not be manually updated. //
//////////////////////////////////////////////////////////////////////////////////////////////

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id            String         @id() @default(cuid())
  email         String         @unique()
  name          String
  password      String
  role          Role           @default(USER)
  products      Product[]
  tasks         Task[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt()
}

model RefreshToken {
  id        String   @id() @default(cuid())
  token     String   @unique()
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id          String     @id() @default(cuid())
  name        String     @unique()
  description String?
  products    Product[]
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt()
}

model Task {
  id          String     @id() @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt()
}

model Event {
  id          String    @id() @default(cuid())
  title       String
  startDate   DateTime
  endDate     DateTime?
  description String?
  allDay      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()
}

model Attachment {
  id          String   @id() @default(cuid())
  filename    String
  storedName  String   @unique()
  mimeType    String
  size        Int
  entityModel String?
  entityId    String?
  url         String
  createdAt   DateTime @default(now())
}

model Product {
  id            String   @id() @default(cuid())
  code          String   @unique()
  barcode       String?
  spec          String?
  size          String?
  name          String
  price         Float
  stockQuantity Int      @default(0)
  totalValue    Float?
  /// @computed: price * stockQuantity (managed by DB)
  description   String?
  isPublic      Boolean  @default(true)
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String
  owner         User     @relation(fields: [ownerId], references: [id])
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt()
}
