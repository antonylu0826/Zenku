datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String    @id() @default(cuid())
  email     String    @unique()
  name      String
  password  String
  role      Role      @default(USER)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
}

model Category {
  id          String    @id() @default(cuid())
  name        String    @unique()
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()
}

model Product {
  id            String   @id() @default(cuid())
  code          String   @unique()
  name          String
  price         Float
  stockQuantity Int      @default(0)
  totalValue    Float?
  /// @computed: price * stockQuantity (managed by DB)
  description   String?
  isPublic      Boolean  @default(true)
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String
  owner         User     @relation(fields: [ownerId], references: [id])
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt()
}
