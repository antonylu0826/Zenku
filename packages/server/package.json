{
  "name": "@zenku/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "seed": "bun --env-file=../../.env run src/seed.ts",
    "gen": "zenstack generate && prisma generate",
    "db-push": "bunx prisma db push --env-file=../../.env --accept-data-loss",
    "test": "NODE_ENV=test JWT_SECRET=test-secret-at-least-32-chars-long bun test --env-file=../../.env tests/",
    "eject": "bun run src/eject.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "^6",
    "@zenku/core": "workspace:*",
    "@zenstackhq/runtime": "2.22.1",
    "hono": "^4",
    "pluralize": "^8.0.0",
    "prisma": "^6",
    "zenstack": "^2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pluralize": "^0.0.33"
  }
}